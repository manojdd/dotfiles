# Global Settings
max-history=50
sort=-time
layer=overlay
anchor=top-right

# Style Options
font=JetBrainsMono Nerd Font 16
width=700
height=110
margin=20
padding=15
border-size=2
border-radius=12
icons=1
max-icon-size=64
default-timeout=5000
ignore-timeout=1

# Colors (Catppuccin Mocha Palette)
background-color=#1e1e2e
text-color=#cdd6f4
border-color=#89b4fa
progress-color=over #313244

# Urgency Specifics
[urgency=low]
border-color=#a6adc8
default-timeout=2000

[urgency=normal]
border-color=#89b4fa

[urgency=high]
border-color=#f38ba8
default-timeout=0

# Application Specific Overrides
[app-name=Spotify]
format=<b>%s</b>\n%b
border-color=#1ed760

[app-name=Discord]
border-color=#5865f2

[app-name=break-alert]
anchor=center
width=500
height=200
background-color=#ff0000

# Ensure KDE Connect notifications stand out
# [app-name="kdeconnect"]
[app-name="KDE Connect"]
border-color=#3daee9
default-timeout=20000
group-by=app-name

# Specifically handle incoming calls (often higher urgency)
[category="im.received"]
border-color=#ff0000
default-timeout=0 
